{
  "expo": {
    "name": "PokeCollect",
    "slug": "PokeCollect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon_io/android-chrome-512x512.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/favicon_io/android-chrome-512x512.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/favicon_io/apple-touch-icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Utilisé pour scanner tes cartes Pokémon et les identifier automatiquement."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon_io/android-chrome-192x192.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon_io/favicon-32x32.png"
    }
  }
}
